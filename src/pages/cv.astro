---
import { Image } from "astro:assets";
import { type CollectionEntry, getCollection } from "astro:content";
import "../global.css";

import { CERTIFICATES, SITE } from "../constants";

import Socials from "../components/composed/socials.astro";
import Head from "../components/head.astro";

import { getLangFromUrl, useTranslations } from "../lib/i18n";
import { cn } from "../lib/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const experiencesCollection: CollectionEntry<"experiences">[] =
  await getCollection("experiences");

const experiences = experiencesCollection.filter((entry) =>
  entry.slug.includes(lang)
);
---

<!doctype html>
<html lang={Astro.currentLocale}>
  <head>
    <meta name="robots" content="noindex" />
    <Head
      title={SITE.TITLE}
      description={SITE.DESCRIPTION}
      image={SITE.OPEN_GRAPH.IMAGE}
    />
    <style>
      @page {
        size: A4;
        margin: 0;
      }
    </style>
  </head>
  <body class="print:text-xs" itemscope itemtype="https://schema.org/Person">
    <main class="py-0">
      <div class="flex flex-col md:flex-row h-full">
        <div class="md:flex-1 p-8 min-h-screen h-full">
          <header>
            <h1
              class="print:text-2xl text-4xl font-bold text-zinc-950"
              itemprop="name"
            >
              Donald Silveira
            </h1>
            <h2
              class="print:text-base text-lg font-medium pb-2"
              itemprop="jobTitle"
            >
              Full-Stack & Mobile Engineer
            </h2>
            <address>
              <Socials>
                <li class="-mt-2">
                  <a
                    href="https://linkedin.com/in/donaldsilveira"
                    itemprop="sameAs"
                  >
                    linkedin.com/in/donaldsilveira
                  </a>
                </li>
                <li class="-mt-2">
                  <a href="mailto:donaldsilveira@gmail.com" itemprop="email">
                    donaldsilveira@gmail.com
                  </a>
                </li>
                <li class="-mt-2">
                  <a href="tel:+5551982426594" itemprop="telephone">
                    +55 51 98242-6594
                  </a>
                </li>
              </Socials>
            </address>
          </header>

          <section class="pt-12 pb-4">
            <h3 class="print:text-base text-lg font-bold text-zinc-950 mb-2">
              Summary
            </h3>
            <p
              class="text-zinc-700 dark:text-zinc-300 leading-relaxed"
              itemprop="description"
            >
              {t("cv.summary")}
            </p>
          </section>

          <section
            class="pt-6 space-y-2"
            itemscope
            itemtype="https://schema.org/ItemList"
          >
            <h3 class="print:text-base text-lg font-bold text-zinc-950">
              Work Experience
            </h3>
            {
              experiences.map((exp) => (
                <article
                  class={cn(
                    "pb-2",
                    exp.slug.includes("lighthouse")
                      ? "print:break-before-page print:pt-8"
                      : ""
                  )}
                  itemscope
                  itemtype="https://schema.org/OrganizationRole"
                >
                  <div class="flex items-center">
                    <h4
                      class="flex-1 font-medium text-zinc-950 dark:text-zinc-50"
                      itemprop="roleName"
                    >
                      {exp.data.role}
                    </h4>
                    <time
                      class="font-medium"
                      datetime={`${exp.data.startYear}/${exp.data.endYear}`}
                    >
                      {exp.data.startYear} - {exp.data.endYear}
                    </time>
                  </div>

                  <a
                    href={exp.data.link}
                    class="text-zinc-600"
                    itemprop="worksFor"
                    itemscope
                    itemtype="https://schema.org/Organization"
                  >
                    <span itemprop="name">{exp.data.company}</span>
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      class="w-4 h-4"
                      aria-hidden="true"
                    >
                      <path d="M7 7h10v10" />
                      <path d="M7 17 17 7" />
                    </svg>
                  </a>

                  {exp.data.description.map((desc) => (
                    <p class="pt-2" itemprop="description">
                      <Fragment set:html={desc} />
                    </p>
                  ))}
                </article>
              ))
            }
          </section>

          <section
            class="pt-6 print:break-after-page space-y-2"
            itemscope
            itemtype="https://schema.org/ItemList"
          >
            <h3 class="print:text-base text-lg font-bold text-zinc-950">
              Certifications
            </h3>
            {
              CERTIFICATES.map((cert) => (
                <article
                  class="pb-2"
                  itemscope
                  itemtype="https://schema.org/EducationalOccupationalCredential"
                >
                  <a
                    href={cert.link}
                    class="text-zinc-600 hover:text-zinc-950 dark:hover:text-zinc-50"
                    itemprop="credentialCategory"
                  >
                    <h4
                      class="font-medium text-zinc-950 dark:text-zinc-50 inline"
                      itemprop="name"
                    >
                      {cert.title}
                    </h4>
                    <span class="text-zinc-500 dark:text-zinc-400">
                      {" "}
                      · {cert.insitution}
                    </span>
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      class="w-3 h-3 inline ml-1"
                      aria-hidden="true"
                    >
                      <path d="M7 7h10v10" />
                      <path d="M7 17 17 7" />
                    </svg>
                  </a>
                </article>
              ))
            }
          </section>
        </div>
        <aside
          class="print:max-w-[240px] md:max-w-[400px] min-h-screen h-full bg-zinc-950 text-white print:p-4 p-8 space-y-8"
        >
          <div class="flex items-center justify-center">
            <Image
              src="/me.jpg"
              alt="Donald Silveira"
              width={140}
              height={140}
              class="rounded-md grayscale"
              itemprop="image"
            />
          </div>
          <section class="flex flex-col space-y-4">
            <h3 class="print:text-base text-lg font-bold">About</h3>
            <div class="[&>a]:text-zinc-400" itemprop="description">
              <p>
                <Fragment set:html={t("home.hero.description.1")} />
              </p>
              <p class="pt-4">
                <Fragment set:html={t("home.hero.description.2")} />
              </p>
            </div>
          </section>

          <section
            class="flex flex-col space-y-4"
            itemscope
            itemtype="https://schema.org/ItemList"
          >
            <h3 class="print:text-base text-lg font-bold">Skills</h3>

            <div class="flex flex-col space-y-3">
              <div>
                <div class="font-medium mb-1">Core Stack</div>
                <div class="text-zinc-400">
                  TypeScript, JavaScript, React, React Native, Next.js, Node.js
                </div>
              </div>
              <div>
                <div class="font-medium mb-1">Backend & Data</div>
                <div class="text-zinc-400">Go, Python, Node.js, SQL, NoSQL</div>
              </div>
              <div>
                <div class="font-medium mb-1">Infrastructure & Delivery</div>
                <div class="text-zinc-400">AWS, Azure, GCP, CI/CD</div>
              </div>
              <div>
                <div class="font-medium mb-1">AI & Automation</div>
                <div class="text-zinc-400">
                  LLM integrations, workflow automation
                </div>
              </div>
            </div>
          </section>

          <section
            class="flex flex-col space-y-4"
            itemscope
            itemtype="https://schema.org/ItemList"
          >
            <h3 class="print:text-base text-lg font-bold">Languages</h3>

            <div class="grid grid-cols-2 items-center gap-4">
              <div
                itemprop="itemListElement"
                itemscope
                itemtype="https://schema.org/ListItem"
              >
                <span itemprop="name">Português</span>
              </div>
              <div class="text-zinc-400" itemprop="description">Native</div>
              <div
                itemprop="itemListElement"
                itemscope
                itemtype="https://schema.org/ListItem"
              >
                <span itemprop="name">English</span>
              </div>
              <div class="text-zinc-400" itemprop="description">Proficient</div>
            </div>
          </section>
        </aside>
      </div>
    </main>
  </body>
</html>
